generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model meta_fields {
  id          Int         @id @default(autoincrement())
  tableId     Int
  name        String
  label       String
  type        String
  isRequired  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  inputType   String      @default("text")
  options     String?
  meta_tables meta_tables @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model meta_relations {
  id          Int         @id @default(autoincrement())
  tableId     Int
  targetModel String
  targetLabel String
  foreignKey  String
  createdAt   DateTime    @default(now())
  meta_tables meta_tables @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model meta_tables {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  slug           String           @unique
  title          String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  isSystem       Boolean          @default(false)
  meta_fields    meta_fields[]
  meta_relations meta_relations[]
}

model t_dynamic_table {
  id Int @id @default(autoincrement())
}

